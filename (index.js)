import express from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
import OpenAI from 'openai';

// Setup
dotenv.config();
const app = express();
const PORT = process.env.PORT || 5000;

// Middleware
app.use(cors()); // Frontend ko connect karne ke liye
app.use(express.json()); // JSON data samajhne ke liye

// OpenAI Configuration
const openai = new OpenAI({
  apiKey: process.env.OPENAI_API_KEY,
});

// --- ROUTES ---

// 1. Health Check (Check karne ke liye server chal raha hai ya nahi)
app.get('/', (req, res) => {
  res.send('AI Mastermind Server is Running! 🚀');
});

// 2. AI Chat Route (Asli AI connection)
app.post('/api/chat', async (req, res) => {
  const { message, history } = req.body;

  try {
    console.log(`User asked: ${message}`);

    const response = await openai.chat.completions.create({
      model: "gpt-3.5-turbo", // Ya "gpt-4"
      messages: [
        { role: "system", content: "You are LinguaMate, an advanced multilingual AI assistant." },
        ...history, // Purani chat yaad rakhne ke liye
        { role: "user", content: message }
      ],
    });

    const aiMessage = response.choices[0].message.content;
    res.json({ reply: aiMessage });

  } catch (error) {
    console.error("AI Error:", error);
    res.status(500).json({ error: "AI server busy or API key invalid." });
  }
});

// Start Server
app.listen(PORT, () => {
  console.log(`-----------------------------------------`);
  console.log(`🚀 Server is live at: http://localhost:${PORT}`);
  console.log(`-----------------------------------------`);
});
